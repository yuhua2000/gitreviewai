# =================================
# GitReviewAI 配置文件
# =================================
# 复制为 config.yaml 并填写实际值
# 标记 [可选] 的字段有默认值，可留空
# 标记 [Web] 的字段支持在 Web 端「全局设置」中修改
# 启动时 config.yaml 的值会作为初始值导入数据库，之后以数据库为准

# --------------------------------
# 服务配置（基础设施，仅 config.yaml）
# --------------------------------
# HTTP 服务端口 [可选]
port: 8080

# 登录密码（必填）
password: "your-login-password"

# JWT 签名密钥（必填，至少 32 字符）
jwt_secret: "your-jwt-secret-key-at-least-32-chars"

# JWT 过期时间 [可选] [Web]
jwt_expiry: "24h"

# 数据库文件路径 [可选]
db_path: "./data/gitreviewai.db"

# 日志级别: debug / info / warn / error [可选] [Web]
log_level: "info"

# --------------------------------
# GitLab 配置 [Web]
# --------------------------------
# 首次启动时导入数据库，之后可在 Web 端修改
# 留空则需要在 Web 端「全局设置」中配置后才能开始审查

# GitLab 服务器地址
gitlab_url: "https://gitlab.com"

# GitLab Personal Access Token
# 获取方式: GitLab → User Settings → Access Tokens → Add new token
# 需要的权限: api
gitlab_token: ""

# GitLab Webhook Secret Token [可选] [Web]
# 用于验证 Webhook 请求的合法性
# 在 GitLab 项目 Settings → Webhooks 中设置
webhook_token: ""

# --------------------------------
# AI 模型配置 [Web]
# --------------------------------
# 首次启动时作为默认模型导入，之后可在 Web 端「AI 模型」中管理
# 留空则需要在 Web 端配置 AI 模型后才能开始审查

# API Key
openai_api_key: ""

# 模型名称 [可选]
# 推荐: gpt-4o, deepseek-v3, qwen-max 等
openai_model: "gpt-4o"

# API 基础地址 [可选]
# OpenAI: https://api.openai.com/v1
# 百度千帆: https://qianfan.baidubce.com/v2
# DeepSeek: https://api.deepseek.com
openai_base_url: ""

# --------------------------------
# 审核配置 [Web]
# --------------------------------
# 以下配置首次启动时导入数据库，之后可在 Web 端修改

# 单个 MR 最大行级评论数量 [可选] [Web]
max_line_comments: 50

# 忽略的文件/目录列表 [Web]
# 支持 glob 模式（如 *.pb.go）和目录前缀匹配
ignore_paths:
  - ".git"
  - "vendor"
  - "node_modules"
  - "dist"
  - "build"
  - "target"
  - "*.pb.go"
  - "*.pb.gw.go"
  - "*_gen.go"
  - "generated"
  - "testdata"
  - "fixtures"

# --------------------------------
# 加密配置（可选，仅 config.yaml）
# --------------------------------
# 敏感字段加密密钥（用于加密存储 Token/Key）
# 留空则不加密（开发环境建议留空，生产环境建议设置）
# ⚠️ 设置后不可更改，否则已加密数据无法解密
encrypt_key: ""
